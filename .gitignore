# ── Environment (secrets / local config) ─────────────────────────────────────
.env
.env.*
!.env.example
application-local.yml
application-local.properties

# ── Runtime logs & process files ─────────────────────────────────────────────
logs/
*.log
*.pid

# ── Local dev scripts (not part of the Maven modules) ──────────────────────────
scripts/

# ── Local docs & test data ─────────────────────────────────────────────────────
docs/
/test/
# Maven unit tests (local-only; use ** so nested module paths match)
**/src/test/**

# ── Maven / Java build ─────────────────────────────────────────────────────────
target/
build/
*.class

# JARs/WARs except Maven wrapper
*.jar
*.war
*.ear
!**/maven-wrapper.jar

# ── Local caches & large binaries ──────────────────────────────────────────────
.rca-cache/
*.tar.gz
*.zip
apache-maven-3.9.6-bin.tar.gz
openjdk-21.0.4_macos-x64_bin.tar.gz

# ── Kotlin ─────────────────────────────────────────────────────────────────────
.kotlin/

# ── IDE ────────────────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.vscode/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor temp files ──────────────────────────────────────────────────────────
*.tmp
*.swp
*.swo
*~

# ── Frontend (if added later) ──────────────────────────────────────────────────
node_modules/
coverage/

# ── Local HAR captures (upload via API/CLI instead) ────────────────────────────
*.har