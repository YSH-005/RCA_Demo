# Copy to .env and fill in values. Do not commit .env.

MONGODB_URI=
MONGODB_DATABASE=
REDPANDA_BROKERS=
REDPANDA_USERNAME=
REDPANDA_PASSWORD=
GEMINI_API_KEY=

# Graylog — keep stub=true until direct API access works
GRAYLOG_URL=
GRAYLOG_TOKEN=
GRAYLOG_STUB=true

# Kibana — required for real RCA (VPN needed)
KIBANA_URL=
KIBANA_API_KEY=
# Perf/trace index (HAR stitching, A/B/C timing signals)
# Perf/trace index — unquoted for Spring; use scripts/load-env.sh in zsh (not bare source .env)
KIBANA_INDEX_PATTERN=monitoring*
# Exception index for (D) rules
KIBANA_ERROR_INDEX=monitoring*
# Optional: verify script end-to-end against a known HAR incident (UTC timestamps)
# KIBANA_VERIFY_REQUEST_ID=space-e33eeaa4-0e23-48a2-bf3e-7cb2d9f3bff4
# KIBANA_VERIFY_FROM=2026-06-22T07:16:09.212Z
# KIBANA_VERIFY_TO=2026-06-22T07:31:09.212Z
# KIBANA_MAX_RESULTS=50

# Grafana — stub until API token is available
GRAFANA_URL=
GRAFANA_API_KEY=
GRAFANA_STUB=true

# Optional: override .env location for Spring services
# RCA_ENV_FILE=/absolute/path/to/.env
