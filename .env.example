GRAYLOG_URL=
GRAYLOG_TOKEN=
GRAYLOG_STUB=true
GRAYLOG_SESSION_COOKIE=
# Paste only SSO tokens (user.env.type + authentication + session), not the full browser cookie

KIBANA_URL=
KIBANA_API_KEY=
KIBANA_INDEX_PATTERN=monitoring*
KIBANA_ERROR_INDEX=monitoring*


GRAFANA_URL=https://qa6-influxdb.sprinklr.com
